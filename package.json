{
  "name": "bangladeshtaptogo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "run-p --race dev:frontend dev:backend",
    "dev:frontend": "next dev --webpack --experimental-https",
    "dev:backend": "convex dev --typecheck-components",
    "dev:build": "chokidar '../../tsconfig*.json' '../../src/**/*.ts' '../../src/**/*.tsx' -i '**/*.test.ts' -c 'npm run build' --initial",
    "predev": "convex dev --skip-push && node -e \"require('node:fs').mkdirSync('dist',{recursive:true})\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@convex-dev/better-auth": "^0.10.11",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.5",
    "better-auth": "1.4.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "npm-run-all2": "^8.0.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
